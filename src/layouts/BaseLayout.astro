---
import "@styles/global.css";
import AnalyticsTags from "@components/AnalyticsTags.astro";
import SiteHeader from "@components/SiteHeader.astro";
import SiteFooter from "@components/SiteFooter.astro";
import { absoluteUrl, withBase } from "@data/paths";
import { siteConfig } from "@data/site";

interface Props {
  title: string;
  description?: string;
  pathname?: string;
  image?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  hideHeader?: boolean;
}

const {
  title,
  description = siteConfig.description,
  pathname = "/",
  image = siteConfig.defaultOgImage,
  schema,
  noindex = false,
  hideHeader = false
} = Astro.props;

const canonical = absoluteUrl(pathname, siteConfig.siteUrl);
const imageUrl = absoluteUrl(image, siteConfig.siteUrl);
const schemaList = Array.isArray(schema) ? schema : schema ? [schema] : [];
const faviconVersion = "20260325e";
const inlineFavicon =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 160'%3E%3Crect width='160' height='160' rx='36' fill='%23B22624'/%3E%3Cg transform='translate(20 21) scale(0.735)'%3E%3Cpath d='M94 30C82 22 68 18 55 18C27 18 12 42 12 80C12 118 27 142 55 142C68 142 82 138 94 130' stroke='%23F7F2EB' stroke-width='28' stroke-linecap='butt' stroke-linejoin='miter' fill='none'/%3E%3Cpath d='M87 31L120 6L148 24L151 57L143 74L129 50L107 42L92 57L73 41Z' fill='%23F7F2EB'/%3E%3Cpath d='M102 48L126 65L110 78L88 64Z' fill='%23F7F2EB'/%3E%3Cpath d='M87 129L120 154L148 136L151 103L143 86L129 110L107 118L92 103L73 119Z' fill='%23F7F2EB'/%3E%3Cpath d='M102 112L126 95L110 82L88 96Z' fill='%23F7F2EB'/%3E%3C/g%3E%3C/svg%3E";
const favicon16Url = `${withBase("/favicons/favicon-16x16.png")}?v=${faviconVersion}`;
const favicon32Url = `${withBase("/favicons/favicon-32x32.png")}?v=${faviconVersion}`;
const faviconSvgUrl = `${withBase("/favicons/favicon.svg")}?v=${faviconVersion}`;
const faviconIcoUrl = `${withBase("/favicon.ico")}?v=${faviconVersion}`;
const appleTouchIconUrl = `${withBase("/favicons/apple-touch-icon.png")}?v=${faviconVersion}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={inlineFavicon} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={faviconSvgUrl} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={favicon32Url} sizes="32x32" type="image/png" />
    <link rel="shortcut icon" href={faviconIcoUrl} type="image/x-icon" />
    <link rel="icon" href={favicon16Url} sizes="16x16" type="image/png" />
    <link rel="icon" href={faviconIcoUrl} sizes="any" />
    <link rel="apple-touch-icon" href={appleTouchIconUrl} />
    <link rel="apple-touch-icon-precomposed" href={appleTouchIconUrl} />
    <link rel="manifest" href={withBase("/site.webmanifest")} />
    <meta name="theme-color" content="#120f10" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={imageUrl} />
    <AnalyticsTags />
    {schemaList.map((entry) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <div class="page-shell">
      {!hideHeader && <SiteHeader />}
      <slot />
      <SiteFooter />
    </div>
  </body>
</html>

<script>
  import { initTrackedLinks } from "../scripts/analytics";
  import { initGlobalUi } from "../scripts/ui";

  initTrackedLinks();
  initGlobalUi();
</script>
