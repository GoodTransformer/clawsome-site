---
import { withBase } from "@data/paths";

interface Props {
  endpoint?: string;
  fallbackEmail: string;
  thankYouPath?: string;
}

const { endpoint = "", fallbackEmail, thankYouPath = "/thank-you/" } = Astro.props;
---

<form
  class="contact-form"
  data-contact-form
  data-endpoint={endpoint}
  data-email={fallbackEmail}
  data-thank-you={withBase(thankYouPath)}
>
  <div class="field-grid">
    <label>
      Name
      <input type="text" name="name" autocomplete="name" required />
    </label>
    <label>
      Business
      <input type="text" name="business" autocomplete="organization" required />
    </label>
    <label>
      Email
      <input type="email" name="email" autocomplete="email" required />
    </label>
    <label>
      Best first agent
      <select name="quickWin" required>
        <option value="Meta Ads">Meta Ads</option>
        <option value="Lead Response">Lead Response</option>
        <option value="Admin Recovery">Admin Recovery</option>
        <option value="Not sure yet">Not sure yet</option>
      </select>
    </label>
  </div>

  <label>
    Where time goes
    <textarea
      name="workflow"
      required
      placeholder="What is slow, repetitive, or getting missed?"
    ></textarea>
  </label>

  <label>
    Helpful context
    <textarea
      name="message"
      placeholder="Optional. Tools, volume, timing, or anything else that helps."
    ></textarea>
  </label>

  <div class="button-row">
    <button class="button primary" type="submit">Send us the workflow</button>
  </div>
  <p class="form-status" data-form-status aria-live="polite"></p>
</form>

<script>
  import { initContactForm } from "../scripts/contact";

  initContactForm();
</script>
