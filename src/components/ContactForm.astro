---
import { withBase } from "@data/paths";

interface Props {
  endpoint?: string;
  fallbackEmail: string;
  thankYouPath?: string;
}

const { endpoint = "", fallbackEmail, thankYouPath = "/thank-you/" } = Astro.props;
---

<form
  class="contact-form"
  data-contact-form
  data-endpoint={endpoint}
  data-email={fallbackEmail}
  data-thank-you={withBase(thankYouPath)}
>
  <div class="field-grid">
    <label>
      Name
      <input type="text" name="name" autocomplete="name" required />
    </label>
    <label>
      Business
      <input type="text" name="business" autocomplete="organization" required />
    </label>
    <label>
      Email
      <input type="email" name="email" autocomplete="email" required />
    </label>
    <label>
      Website
      <input type="url" name="website" placeholder="https://example.com" />
    </label>
    <label>
      Best first quick win
      <select name="quickWin" required>
        <option value="Meta Ads Agent">Meta Ads Agent</option>
        <option value="Lead Response Agent">Lead Response Agent</option>
        <option value="Admin Recovery Agent">Admin Recovery Agent</option>
        <option value="Not sure yet">Not sure yet</option>
      </select>
    </label>
    <label>
      Lead volume, spend, or admin time
      <input type="text" name="context" placeholder="Optional context that helps scope the first win" />
    </label>
  </div>

  <label>
    What workflow is causing drag?
    <textarea name="workflow" required></textarea>
  </label>

  <label>
    Message
    <textarea name="message" placeholder="Optional detail about systems, timings, or the current process"></textarea>
  </label>

  <div class="button-row">
    <button class="button primary" type="submit">Send audit request</button>
  </div>
  <p class="form-status" data-form-status aria-live="polite"></p>
</form>

<script>
  import { initContactForm } from "../scripts/contact";

  initContactForm();
</script>
