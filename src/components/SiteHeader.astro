---
import Logo from "./Logo.astro";
import { withBase } from "@data/paths";
import { getPrimaryCtaHref, primaryNavigation } from "@data/site";

const normalizePath = (value: string) => (value !== "/" ? value.replace(/\/$/, "") : value);
const isHome = normalizePath(Astro.url.pathname) === normalizePath(withBase("/"));
const primaryHref = getPrimaryCtaHref();
---

<header class="site-header" data-site-header data-scrolled="false" data-home={isHome ? "true" : "false"}>
  <div class="site-header__inner">
    <a href={withBase("/")} aria-label="Clawsome home" class="site-brand">
      <Logo tone="light" />
    </a>

    <nav class="site-nav" aria-label="Primary">
      {primaryNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      {!isHome && (
        <a
          href={withBase(primaryHref)}
          class="button secondary nav-cta"
          target={primaryHref.startsWith("http") ? "_blank" : undefined}
          rel={primaryHref.startsWith("http") ? "noreferrer" : undefined}
        >
          Book an audit
        </a>
      )}
      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-menu-toggle
      >
        <span class="sr-only">Toggle navigation</span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-navigation" data-mobile-nav data-open="false">
    <nav aria-label="Mobile">
      {primaryNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
