---
import Logo from "./Logo.astro";
import ButtonLink from "./ButtonLink.astro";
import { withBase } from "@data/paths";
import { getPrimaryCtaHref, primaryNavigation } from "@data/site";
---

<header class="site-header" data-site-header data-scrolled="false">
  <div class="site-header__inner">
    <a href={withBase("/")} aria-label="Clawsome home">
      <Logo tone="light" />
    </a>

    <nav class="site-nav" aria-label="Primary">
      {primaryNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <ButtonLink
        href="/example-agents/"
        variant="secondary"
        track="secondary_cta_click"
        trackLabel="Header example agents"
      >
        See example agents
      </ButtonLink>
      <ButtonLink
        href={getPrimaryCtaHref()}
        variant="primary"
        external={getPrimaryCtaHref().startsWith("http")}
        track="primary_cta_click"
        trackLabel="Header book audit"
      >
        Book a quick-win audit
      </ButtonLink>
      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-menu-toggle
      >
        <span class="sr-only">Open navigation</span>
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none">
          <path d="M4 7H20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          <path d="M4 12H20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          <path d="M4 17H20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-navigation" data-mobile-nav data-open="false">
    <nav aria-label="Mobile">
      {primaryNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
      <ButtonLink
        href={getPrimaryCtaHref()}
        variant="primary"
        external={getPrimaryCtaHref().startsWith("http")}
        track="primary_cta_click"
        trackLabel="Mobile book audit"
      >
        Book a quick-win audit
      </ButtonLink>
    </nav>
  </div>
</header>
