---
import Logo from "./Logo.astro";
import ButtonLink from "./ButtonLink.astro";
import { withBase } from "@data/paths";
import { getPrimaryCtaHref, primaryNavigation } from "@data/site";

const primaryHref = getPrimaryCtaHref();
---

<header class="site-header" data-site-header data-scrolled="false">
  <div class="site-header__inner">
    <a href={withBase("/")} aria-label="Clawsome home" class="site-brand">
      <Logo tone="dark" />
    </a>

    <nav class="site-nav" aria-label="Primary">
      {primaryNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <ButtonLink
        href={primaryHref}
        variant="primary"
        external={primaryHref.startsWith("http")}
        track="primary_cta_click"
        trackLabel="Header book audit"
        className="header-cta"
      >
        Book an audit
      </ButtonLink>
      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-menu-toggle
      >
        <span class="sr-only">Open navigation</span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-navigation" data-mobile-nav data-open="false">
    <nav aria-label="Mobile">
      {primaryNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
      <ButtonLink
        href={primaryHref}
        variant="primary"
        external={primaryHref.startsWith("http")}
        track="primary_cta_click"
        trackLabel="Mobile book audit"
      >
        Book an audit
      </ButtonLink>
    </nav>
  </div>
</header>
