---
import ButtonLink from "./ButtonLink.astro";
import CTASection from "./CTASection.astro";
import PageHero from "./PageHero.astro";
import type { UseCase } from "@data/types";

interface Props {
  useCase: UseCase;
}

const { useCase } = Astro.props;
---

<PageHero
  eyebrow="Example agent"
  title={useCase.name}
  text={useCase.summary}
  bullets={useCase.outcomes}
/>

<section class="section" data-tone="paper">
  <div class="container split-grid">
    <div class="about-panel rich-text" data-reveal>
      <span class="eyebrow">Workflow pain</span>
      <h2>Where the drag usually sits.</h2>
      <p>{useCase.pain}</p>
      <p>{useCase.whyItSells}</p>
    </div>
    <div class="about-panel rich-text" data-reveal>
      <span class="eyebrow">What the agent does</span>
      <h2>One bounded workflow, handled cleanly.</h2>
      <ul class="list">
        {useCase.whatItDoes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="section" data-tone="sand">
  <div class="container">
    <div class="section-intro" data-reveal>
      <span class="eyebrow">Workflow outline</span>
      <h2>How the use case moves.</h2>
      <p class="muted">
        The point is not vague autonomy. It is a clear sequence with explicit hand-offs and obvious supervision.
      </p>
    </div>
    <div class="grid-3">
      {useCase.workflow.map((step, index) => (
        <article class="step-panel" data-reveal>
          <span class="step-number">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p class="muted">{step.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section" data-tone="paper">
  <div class="container split-grid">
    <article class="about-panel" data-reveal>
      <span class="eyebrow">What stays human</span>
      <h2>Control stays where it should.</h2>
      <ul class="list">
        {useCase.whatStaysHuman.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
    <article class="about-panel" data-reveal>
      <span class="eyebrow">Commercial outcomes</span>
      <h2>What the proof should show.</h2>
      <ul class="list">
        {useCase.proofAngles.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <ul class="mini-meta">
        {useCase.outcomes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </div>
</section>

<section class="section" data-tone="ink">
  <div class="container split-grid">
    <article class="trust-panel" data-reveal>
      <span class="eyebrow">Trust and control</span>
      <h2>Built to be supervised.</h2>
      <ul class="list">
        {useCase.trustNotes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
    <article class="trust-panel" data-reveal>
      <span class="eyebrow">Best fit</span>
      <h2>Who this suits best.</h2>
      <ul class="list">
        {useCase.whoItSuits.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <div class="button-row" style="margin-top: 1.5rem;">
        <ButtonLink href="/contact/" variant="primary" track="use_case_page_conversion" trackLabel={useCase.name}>
          {useCase.ctaLabel}
        </ButtonLink>
      </div>
    </article>
  </div>
</section>

<CTASection secondaryHref="/contact/" />
