---
import type { ProofAsset } from "@data/types";
import { withBase } from "@data/paths";

interface Props {
  items: ProofAsset[];
}

const { items } = Astro.props;
---

<div class="proof-grid">
  {items.map((item) => (
    <article class="proof-panel" data-reveal>
      <div class="proof-figure">
        <img src={withBase(item.href)} alt={item.title} loading="lazy" />
      </div>
      <p class="kicker">{item.type}</p>
      <h3>{item.title}</h3>
      <p class="muted">{item.description}</p>
      <p>{item.status}</p>
      <a class="panel-link" href={withBase(item.href)} data-track="proof_asset_play" data-track-label={item.title}>
        <span>Open placeholder</span>
        <span aria-hidden="true">→</span>
      </a>
    </article>
  ))}
</div>
