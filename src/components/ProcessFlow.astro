---
import type { ProcessStep } from "@data/types";

interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;
---

<div class="step-flow">
  {steps.map((step) => (
    <article class="step-panel" data-reveal>
      <span class="step-number">{step.index}</span>
      <h3>{step.title}</h3>
      <p class="muted">{step.detail}</p>
    </article>
  ))}
</div>
