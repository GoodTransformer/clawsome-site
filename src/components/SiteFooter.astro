---
import Logo from "./Logo.astro";
import { withBase } from "@data/paths";
import {
  footerNavigation,
  getPrimaryCtaHref,
  legalNavigation
} from "@data/site";

const primaryHref = getPrimaryCtaHref();
---

<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-brand">
      <a href={withBase("/")} aria-label="Clawsome home">
        <Logo tone="light" />
      </a>
      <p>We set up practical AI agents for SMEs.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      {footerNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>

    <div class="footer-links">
      <a
        href={primaryHref}
        target={primaryHref.startsWith("http") ? "_blank" : undefined}
        rel={primaryHref.startsWith("http") ? "noreferrer" : undefined}
      >
        Book an audit
      </a>
    </div>
  </div>

  <div class="container footer-meta">
    <div class="footer-legal">
      {legalNavigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </div>
  </div>
</footer>
