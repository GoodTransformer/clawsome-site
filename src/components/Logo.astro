---
import BrandMark from "./BrandMark.astro";

interface Props {
  tone?: "light" | "dark";
  wordmark?: boolean;
}

const { tone = "dark", wordmark = true } = Astro.props;
---

<span class="logo-lockup" aria-label="Clawsome">
  <span class="logo-mark" aria-hidden="true">
    <BrandMark tone="red" />
  </span>
  {wordmark && (
    <span class={`logo-lockup__word ${tone === "light" ? "is-light" : "is-dark"}`}>Clawsome</span>
  )}
</span>
