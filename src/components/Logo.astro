---
interface Props {
  tone?: "light" | "dark";
  wordmark?: boolean;
}

const { tone = "light", wordmark = true } = Astro.props;
const stroke = tone === "light" ? "#F7F3EC" : "#0B1011";
const accent = tone === "light" ? "#79EBCD" : "#1F9A88";
---

<span class="logo-lockup" aria-label="Clawsome">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M23 32C23 25.373 28.373 20 35 20H60V44H41C37.686 44 35 46.686 35 50V61H23V32Z"
        fill={stroke}
      />
      <path
        d="M97 88C97 94.627 91.627 100 85 100H60V76H79C82.314 76 85 73.314 85 70V59H97V88Z"
        fill={stroke}
      />
      <path
        d="M60 20H85C91.627 20 97 25.373 97 32V61H85V50C85 46.686 82.314 44 79 44H60V20Z"
        fill={accent}
      />
      <path
        d="M60 100H35C28.373 100 23 94.627 23 88V59H35V70C35 73.314 37.686 76 41 76H60V100Z"
        fill={accent}
      />
      <rect x="51" y="35" width="18" height="50" rx="9" fill={tone === "light" ? "rgba(247,243,236,0.16)" : "rgba(11,16,17,0.1)"} />
    </svg>
  </span>
  {wordmark && <span class="logo-lockup__word">Clawsome</span>}
</span>
