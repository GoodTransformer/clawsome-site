---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  bullets?: string[];
}

const { eyebrow, title, text, bullets = [] } = Astro.props;
---

<section class="page-hero">
  <div class="container page-hero__content">
    <div data-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p class="lede muted">{text}</p>
    </div>

    {bullets.length > 0 && (
      <ul class="hero-stat-list" data-reveal>
        {bullets.map((bullet) => (
          <li>{bullet}</li>
        ))}
      </ul>
    )}
  </div>
</section>
