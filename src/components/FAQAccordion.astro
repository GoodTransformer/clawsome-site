---
import type { FaqItem } from "@data/types";

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="faq-list">
  {items.map((item) => (
    <details class="faq-item">
      <summary>{item.question}</summary>
      <div class="faq-answer">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>
