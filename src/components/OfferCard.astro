---
import type { Offer } from "@data/types";

interface Props {
  offer: Offer;
}

const { offer } = Astro.props;
---

<article class="offer-panel" data-reveal>
  <p class="kicker">{offer.role}</p>
  <h3>{offer.name}</h3>
  <p class="muted">{offer.purpose}</p>
  <p>{offer.scope}</p>
  <ul class="list">
    {offer.includes.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
  <ul class="mini-meta">
    <li>{offer.pricing}</li>
    <li>{offer.suits}</li>
  </ul>
</article>
