---
import BaseLayout from "@layouts/BaseLayout.astro";
import { cookieSections } from "@data/legal";
---

<BaseLayout
  title="Cookie Notice | Clawsome"
  description="Cookie and data notice template for the Clawsome website."
  pathname="/cookie-notice/"
>
  <section class="page-hero">
    <div class="container page-hero__shell">
      <div>
        <p class="eyebrow">Cookies</p>
        <h1>Cookie notice.</h1>
        <p class="page-intro">Built to stay lean. Review before live analytics go in.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container legal-shell">
      {cookieSections.map((section) => (
        <article class="legal-block">
          <h2>{section.heading}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
