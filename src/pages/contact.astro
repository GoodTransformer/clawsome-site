---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import ContactForm from "@components/ContactForm.astro";
import { serviceSchema } from "@data/schema";
import { siteConfig } from "@data/site";

const formEndpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT || "";
---

<BaseLayout
  title="Contact | Clawsome"
  description="Tell us what needs fixing. We will tell you if it is a good fit for a first agent."
  pathname="/contact/"
  schema={serviceSchema(
    "Contact Clawsome",
    "Tell Clawsome what needs fixing and get a view on whether it is a good fit for a first agent.",
    "/contact/"
  )}
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <h1>Tell us what needs fixing.</h1>
        <p class="page-intro">We will tell you if it is a good fit for a first agent.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container contact-shell">
      <aside class="contact-aside">
        <h2>Get in touch.</h2>
        <p>Send us the workflow and we will come back with the best next step.</p>
        <div class="button-row">
          <ButtonLink
            href="#contact-form"
            variant="primary"
            track="primary_cta_click"
            trackLabel="Contact page send workflow"
          >
            Send us the workflow
          </ButtonLink>
        </div>
        <p class="contact-aside__line">Clear setup. Clean handover. Staff training included.</p>
      </aside>

      <div class="contact-form-shell" id="contact-form">
        <h2>Send us the workflow.</h2>
        <ContactForm endpoint={formEndpoint} fallbackEmail={siteConfig.email} />
      </div>
    </div>
  </section>
</BaseLayout>
