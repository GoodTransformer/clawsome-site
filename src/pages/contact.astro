---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import ContactForm from "@components/ContactForm.astro";
import Logo from "@components/Logo.astro";
import { serviceSchema } from "@data/schema";
import {
  getContactEmailHref,
  getPrimaryCtaHref,
  isPlaceholderValue,
  siteConfig
} from "@data/site";

const bookingHref = getPrimaryCtaHref();
const formEndpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT || "";
const bookingTarget = isPlaceholderValue(siteConfig.bookingUrl) ? "#audit-form" : bookingHref;
---

<BaseLayout
  title="Contact | Clawsome"
  description="Tell Clawsome the workflow. We will tell you if it is a good first agent."
  pathname="/contact/"
  schema={serviceSchema(
    "Contact Clawsome",
    "Tell Clawsome the workflow and get a view on whether it is a strong first AI agent build.",
    "/contact/"
  )}
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <div class="page-hero__brand">
          <Logo tone="dark" />
        </div>
        <h1>Tell us the workflow.</h1>
        <p class="page-intro">We will tell you if it is a strong first build.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container contact-shell">
      <aside class="contact-aside">
        <h2>Take the clearest next step.</h2>
        <p>If the workflow is clear, book the audit. If not, send the brief.</p>
        <div class="button-row">
          <ButtonLink
            href={bookingTarget}
            variant="primary"
            external={bookingTarget.startsWith("http")}
            track="booking_link_click"
            trackLabel="Contact page book audit"
          >
            Book an audit
          </ButtonLink>
          {!isPlaceholderValue(siteConfig.email) && (
            <ButtonLink href={getContactEmailHref()} variant="secondary">
              Email Clawsome
            </ButtonLink>
          )}
        </div>
        <div class="contact-note">
          <p>OpenClaw for action. Claude for reasoning. Human approval where it matters.</p>
          <p>{siteConfig.credibilityNote}</p>
        </div>
      </aside>

      <div class="contact-form-shell" id="audit-form">
        <h2>Send the workflow.</h2>
        <ContactForm endpoint={formEndpoint} fallbackEmail={siteConfig.email} />
      </div>
    </div>
  </section>
</BaseLayout>
