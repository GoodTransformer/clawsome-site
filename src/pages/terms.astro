---
import BaseLayout from "@layouts/BaseLayout.astro";
import Logo from "@components/Logo.astro";
import { termsSections } from "@data/legal";
---

<BaseLayout
  title="Terms | Clawsome"
  description="Simple website terms for the Clawsome marketing site."
  pathname="/terms/"
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <div class="page-hero__brand">
          <Logo tone="dark" />
        </div>
        <h1>Website terms.</h1>
        <p class="page-intro">Simple public-site terms, separate from project agreements.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container legal-shell">
      {termsSections.map((section) => (
        <article class="legal-block">
          <h2>{section.heading}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
