---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import { serviceSchema } from "@data/schema";
import { detailedProcessSteps, getPrimaryCtaHref, trustPrinciples } from "@data/site";

const primaryHref = getPrimaryCtaHref();
---

<BaseLayout
  title="How It Works | Clawsome"
  description="Audit, build, operator training, handover, and expansion once the first agent proves itself."
  pathname="/how-it-works/"
  schema={serviceSchema(
    "How Clawsome works",
    "Audit, bounded build, operator training, handover, optional care, then expansion from proof.",
    "/how-it-works/"
  )}
>
  <section class="page-hero">
    <div class="container page-hero__shell">
      <div>
        <p class="eyebrow">How it works</p>
        <h1>Built to land cleanly.</h1>
        <p class="page-intro">
          One workflow. One operator. One handover path. No mysterious black box dropped into the business.
        </p>
      </div>
      <div class="page-note">
        <p>Audit. Build. Train. Handover. Care if needed.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container process-list">
      {detailedProcessSteps.map((step) => (
        <article class="process-row">
          <span class="process-number">{step.index}</span>
          <div>
            <h2>{step.title}</h2>
            <p>{step.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Control</p>
        <h2>Built-in restraint.</h2>
        <p>Enough control to buy with confidence.</p>
      </div>
      <div class="trust-strip">
        {trustPrinciples.map((item) => (
          <article class="trust-item">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container cta-shell">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Start with the audit.</h2>
        <p>That is where the right first build gets chosen.</p>
      </div>
      <div class="button-row">
        <ButtonLink href={primaryHref} variant="primary" external={primaryHref.startsWith("http")}>
          Book an audit
        </ButtonLink>
        <ButtonLink href="/pricing/" variant="secondary">
          See pricing
        </ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
