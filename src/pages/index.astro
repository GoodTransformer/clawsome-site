---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import BrandMark from "@components/BrandMark.astro";
import Logo from "@components/Logo.astro";
import { offers } from "@data/offers";
import { serviceSchema, organisationSchema, websiteSchema } from "@data/schema";
import { finalCta, getPrimaryCtaHref, homeProcessSteps, siteConfig } from "@data/site";
import { useCases } from "@data/useCases";

const primaryHref = getPrimaryCtaHref();
---

<BaseLayout
  title="Clawsome | Practical AI agents for SMEs"
  description="Agents work now. Clawsome sets up practical OpenClaw and Claude builds for SMEs, starting with one useful quick win."
  pathname="/"
  hideHeader={true}
  schema={[
    organisationSchema,
    websiteSchema,
    serviceSchema("AI agent setup for SMEs", siteConfig.description, "/")
  ]}
>
  <section class="hero">
    <div class="hero-atmosphere" aria-hidden="true"></div>
    <div class="container hero-rail">
      <div class="hero-brand-block">
        <p class="hero-intro">Introducing</p>
        <div class="hero-logo-line">
          <div class="hero-logo">
            <Logo tone="light" />
          </div>
          <p class="hero-brand-note">We make agents</p>
        </div>
      </div>
    </div>
    <div class="container hero-stage">
      <div class="hero-copy">
        <h1>Agents work now.</h1>
        <p class="hero-text">We can set them up for you and start with one useful workflow.</p>
        <div class="button-row hero-actions">
          <ButtonLink
            href={primaryHref}
            variant="primary"
            external={primaryHref.startsWith("http")}
            track="primary_cta_click"
            trackLabel="Home hero book audit"
          >
            Book an audit
          </ButtonLink>
          <ButtonLink
            href="/use-cases/"
            variant="secondary"
            track="secondary_cta_click"
            trackLabel="Home hero use cases"
          >
            See use cases
          </ButtonLink>
        </div>
      </div>
      <div class="hero-mark-wrap" aria-hidden="true">
        <BrandMark tone="red" />
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-head section-head--split">
        <h2>Three quick wins.</h2>
        <ButtonLink href="/use-cases/" variant="ghost">
          Use cases
        </ButtonLink>
      </div>

      <div class="case-list">
        {useCases.map((item, index) => (
          <article class="case-block">
            <div class="case-block__lead">
              <p class="case-index">0{index + 1}</p>
              <div>
                <p class="case-name">{item.name}</p>
                <h3>{item.headline}</h3>
              </div>
            </div>
            <div class="case-block__copy">
              <p class="case-line"><strong>Problem</strong>{item.problem}</p>
              <p class="case-line"><strong>Outcome</strong>{item.outcome}</p>
            </div>
            <ul class="editorial-list editorial-list--compact">
              {item.handles.slice(0, 2).map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
            <div class="case-block__cta">
              <ButtonLink href={`/use-cases/#${item.slug}`} variant="ghost">
                {item.ctaLabel}
              </ButtonLink>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-light" id="how-it-works">
    <div class="container">
      <div class="section-head">
        <h2>Built to land cleanly.</h2>
        <p>OpenClaw for action. Claude for reasoning. Human sign-off where it matters.</p>
      </div>

      <div class="operating-grid">
        {homeProcessSteps.map((step) => (
          <article class="operating-step">
            <p class="process-number">{step.index}</p>
            <h3>{step.title}</h3>
            <p>{step.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <h2>Clear offers.</h2>
          <p>Enough scope to buy with confidence.</p>
        </div>
        <ButtonLink href="/pricing/" variant="ghost">
          Full pricing
        </ButtonLink>
      </div>

      <div class="offer-stack">
        {offers.map((offer, index) => (
          <article class="offer-item">
            <p class="offer-index">0{index + 1}</p>
            <div class="offer-copy">
              <h3>{offer.name}</h3>
              <p>{offer.summary}</p>
            </div>
            <ul class="editorial-list editorial-list--compact">
              {offer.bullets.slice(0, 3).map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
            <div class="offer-price">{offer.price}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container closing-shell">
      <div>
        <h2>{finalCta.title}</h2>
        <p>{finalCta.text}</p>
      </div>
      <div class="button-row">
        <ButtonLink
          href={primaryHref}
          variant="primary"
          external={primaryHref.startsWith("http")}
          track="primary_cta_click"
          trackLabel="Home final book audit"
        >
          {finalCta.primaryLabel}
        </ButtonLink>
        <ButtonLink href="/contact/" variant="secondary">
          {finalCta.secondaryLabel}
        </ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
