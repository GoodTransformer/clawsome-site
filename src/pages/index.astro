---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import BrandMark from "@components/BrandMark.astro";
import Logo from "@components/Logo.astro";
import { offers } from "@data/offers";
import { withBase } from "@data/paths";
import { serviceSchema, organisationSchema, websiteSchema } from "@data/schema";
import { finalCta, getPrimaryCtaHref, homeProcessSteps, primaryNavigation, siteConfig } from "@data/site";
import { useCases } from "@data/useCases";

const primaryHref = getPrimaryCtaHref();
const pricingOffers = offers.slice(0, 3);
const showLayoutTuner = import.meta.env.DEV;
---

<BaseLayout
  title="Clawsome | Practical AI agents for SMEs"
  description="We set up your first useful AI agent by finding the right workflow, building it properly, and training your team to run it."
  pathname="/"
  hideHeader={true}
  schema={[
    organisationSchema,
    websiteSchema,
    serviceSchema("AI agent setup for SMEs", siteConfig.description, "/")
  ]}
>
  <section class="hero">
    <div class="hero-atmosphere" aria-hidden="true"></div>
    <div class="container hero-stage hero-stage--tight">
      <nav class="hero-nav hero-nav--floating" aria-label="Primary">
        {primaryNavigation.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))}
      </nav>

      <div class="hero-copy">
        <div class="hero-brand">
          <Logo tone="light" />
        </div>
        <h1>We set up your first useful AI agent.</h1>
        <p class="hero-text">
          First we find the right workflow. Then we build it, make it work, and train your team to run it.
          Start with one agent doing a job that used to take hours.
        </p>
        <div class="button-row hero-actions">
          <ButtonLink
            href={primaryHref}
            variant="primary"
            external={primaryHref.startsWith("http")}
            track="primary_cta_click"
            trackLabel="Home hero book audit"
          >
            Book an audit
          </ButtonLink>
          <ButtonLink
            href="/#how-it-works"
            variant="secondary"
            track="secondary_cta_click"
            trackLabel="Home hero how we work"
          >
            How we work
          </ButtonLink>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-brand-plane"></div>
        <div class="hero-mark-wrap">
          <BrandMark tone="red" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light" id="how-it-works">
    <div class="container">
      <div class="section-head section-head--compact">
        <h2>How we work</h2>
      </div>

      <div class="home-grid home-grid--three home-grid--process">
        {homeProcessSteps.map((step) => (
          <article class="home-card home-card--process">
            <p class="home-card__index">{step.index}</p>
            <div class="home-card__copy">
              <h3>{step.title}</h3>
              <p>{step.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-head section-head--compact">
        <h2>Example Agents</h2>
      </div>

      <div class="home-grid home-grid--three home-grid--feature">
        {useCases.map((item, index) => (
          <article class="home-card home-card--usecase">
            <p class="home-card__index">0{index + 1}</p>
            <div class="home-card__copy">
              <h3>{item.name}</h3>
              <p class="home-card__subtitle">{item.headline}</p>
              <p>{item.summary}</p>
              <p class="home-card__outcome">{item.outcome}</p>
            </div>
            <div class="home-card__action">
              <ButtonLink href={`/use-cases/#${item.slug}`} variant="ghost">
                {item.ctaLabel}
              </ButtonLink>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container">
      <div class="section-head section-head--compact">
        <h2>Pricing</h2>
      </div>

      <div class="home-grid home-grid--three home-grid--pricing-columns">
        {pricingOffers.map((offer) => (
          <article class="home-card home-card--pricing">
            <div class="home-card__copy">
              <h3>{offer.name}</h3>
              <p>{offer.summary}</p>
            </div>
            <ul class="editorial-list editorial-list--compact">
              {offer.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
            <p class="home-card__price">{offer.price}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container closing-shell">
      <div>
        <h2>{finalCta.title}</h2>
        <p>{finalCta.text}</p>
      </div>
      <div class="button-row">
        <ButtonLink
          href={primaryHref}
          variant="primary"
          external={primaryHref.startsWith("http")}
          track="primary_cta_click"
          trackLabel="Home final book audit"
        >
          {finalCta.primaryLabel}
        </ButtonLink>
        <ButtonLink href="/contact/" variant="secondary">
          {finalCta.secondaryLabel}
        </ButtonLink>
      </div>
    </div>
  </section>

  {showLayoutTuner && (
    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        if (params.get("layout") !== "1") return;

        const root = document.documentElement;
        const mark = document.querySelector(".hero-mark-wrap");
        const nav = document.querySelector(".hero-nav--floating");
        if (!(mark instanceof HTMLElement) && !(nav instanceof HTMLElement)) return;

        document.body.dataset.layoutTune = "on";

        const createTuner = (element, options, index) => {
          if (!(element instanceof HTMLElement)) return;

          element.tabIndex = 0;

          const stored = (() => {
            try {
              return JSON.parse(window.localStorage.getItem(options.storageKey) || "{}");
            } catch {
              return {};
            }
          })();

          const state = {
            x: Number.isFinite(stored.x) ? stored.x : 0,
            y: Number.isFinite(stored.y) ? stored.y : 0
          };

          const panel = document.createElement("div");
          panel.className = "layout-tuner";
          panel.style.bottom = `${1 + index * 8}rem`;
          panel.innerHTML = `
            <strong>${options.title}</strong>
            <p>${options.description}</p>
            <code data-layout-values></code>
            <div class="layout-tuner__actions">
              <button type="button" data-layout-copy>Copy values</button>
              <button type="button" data-layout-reset>Reset</button>
            </div>
          `;
          document.body.append(panel);

          const values = panel.querySelector("[data-layout-values]");
          const copyButton = panel.querySelector("[data-layout-copy]");
          const resetButton = panel.querySelector("[data-layout-reset]");

          const apply = () => {
            root.style.setProperty(options.xVar, `${state.x}px`);
            root.style.setProperty(options.yVar, `${state.y}px`);
            if (values instanceof HTMLElement) {
              values.textContent = `x ${state.x}px, y ${state.y}px`;
            }
            window.localStorage.setItem(options.storageKey, JSON.stringify(state));
          };

          const nudge = (dx, dy) => {
            state.x += dx;
            state.y += dy;
            apply();
          };

          let drag = null;

          element.addEventListener("pointerdown", (event) => {
            if (event.button !== 0) return;
            drag = {
              startX: event.clientX,
              startY: event.clientY,
              originX: state.x,
              originY: state.y
            };
            element.dataset.dragging = "true";
            element.setPointerCapture(event.pointerId);
            element.focus();
            event.preventDefault();
          });

          element.addEventListener("pointermove", (event) => {
            if (!drag) return;
            state.x = Math.round(drag.originX + (event.clientX - drag.startX));
            state.y = Math.round(drag.originY + (event.clientY - drag.startY));
            apply();
          });

          const stopDrag = (event) => {
            if (!drag) return;
            drag = null;
            element.dataset.dragging = "false";
            if (element.hasPointerCapture(event.pointerId)) {
              element.releasePointerCapture(event.pointerId);
            }
          };

          element.addEventListener("pointerup", stopDrag);
          element.addEventListener("pointercancel", stopDrag);

          element.addEventListener("keydown", (event) => {
            const step = event.shiftKey ? 10 : 1;

            if (event.key === "ArrowLeft") nudge(-step, 0);
            else if (event.key === "ArrowRight") nudge(step, 0);
            else if (event.key === "ArrowUp") nudge(0, -step);
            else if (event.key === "ArrowDown") nudge(0, step);
            else return;

            event.preventDefault();
          });

          copyButton?.addEventListener("click", async () => {
            const text = `${options.xVar}: ${state.x}px; ${options.yVar}: ${state.y}px;`;
            try {
              await navigator.clipboard.writeText(text);
              copyButton.textContent = "Copied";
              window.setTimeout(() => {
                copyButton.textContent = "Copy values";
              }, 1200);
            } catch {
              if (values instanceof HTMLElement) values.textContent = text;
            }
          });

          resetButton?.addEventListener("click", () => {
            state.x = 0;
            state.y = 0;
            apply();
          });

          apply();
        };

        createTuner(mark, {
          title: "Hero mark tuner",
          description: "Drag the C. Arrow keys nudge it.",
          storageKey: "clawsome:hero-mark-nudge",
          xVar: "--hero-mark-nudge-x",
          yVar: "--hero-mark-nudge-y"
        }, 0);

        createTuner(nav, {
          title: "Hero nav tuner",
          description: "Drag the nav. Arrow keys nudge it.",
          storageKey: "clawsome:hero-nav-nudge",
          xVar: "--hero-nav-nudge-x",
          yVar: "--hero-nav-nudge-y"
        }, 1);

        nav?.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();
        });
      })();
    </script>
  )}
</BaseLayout>
