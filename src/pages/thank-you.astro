---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import PageHero from "@components/PageHero.astro";
---

<BaseLayout
  title="Thank You | Clawsome"
  description="Thank-you page after a Clawsome audit request."
  pathname="/thank-you/"
  noindex={true}
>
  <PageHero
    eyebrow="Thank you"
    title="Your request is in."
    text="Clawsome will review the workflow note and come back with the next sensible step. If you want to move faster, you can still go straight to the booking route."
  />

  <section class="section" data-tone="paper">
    <div class="container">
      <div class="panel" data-reveal>
        <h2>What happens next</h2>
        <ul class="list">
          <li>The workflow note is reviewed for fit and likely first value</li>
          <li>The next response focuses on the right first quick win, not a generic AI pitch</li>
          <li>If the case is clear, the next move is usually an audit or use-case review</li>
        </ul>
        <div class="button-row" style="margin-top: 1.5rem;">
          <ButtonLink href="/" variant="secondary">Return home</ButtonLink>
          <ButtonLink href="/example-agents/" variant="ghost">Review example agents</ButtonLink>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
