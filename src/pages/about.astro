---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTASection from "@components/CTASection.astro";
import PageHero from "@components/PageHero.astro";
import { serviceSchema } from "@data/schema";
import { siteConfig } from "@data/site";
---

<BaseLayout
  title="About | Clawsome"
  description="Learn what Clawsome is, why it is built around practical quick wins, and why real business workflows matter more than AI theatre."
  pathname="/about/"
  schema={serviceSchema(
    "About Clawsome",
    "Clawsome explains why it is built around practical quick wins, real workflows, and a trust-led delivery model for SMEs.",
    "/about/"
  )}
>
  <PageHero
    eyebrow="About"
    title="Built around practical quick wins from day one."
    text="Clawsome exists to help SMEs begin their agentic journey with one useful workflow that can be understood, bought, supervised, and expanded from proof."
    bullets={[
      "Outcome-led, not consultancy-shaped",
      "OpenClaw plus Claude as the working stack",
      "Real workflow ownership after handover"
    ]}
  />

  <section class="section" data-tone="paper">
    <div class="container about-grid">
      <article class="about-panel rich-text" data-reveal>
        <span class="eyebrow">What Clawsome is</span>
        <h2>A practical setup partner for SMEs.</h2>
        <p>
          Clawsome is not selling a platform story or a research-lab story. It sets up useful AI agents for real business workflows with a clear first step, a bounded scope, and an operator handover that makes the result usable.
        </p>
        <p>
          The point is simple. Start with one quick win. Prove the payoff. Expand from there.
        </p>
      </article>
      <article class="about-panel rich-text" data-reveal>
        <span class="eyebrow">Why this model</span>
        <h2>Because SMEs buy clarity, not theatre.</h2>
        <p>
          Most buyers do not want a maze of AI possibilities. They want somebody to identify the right first workflow, deploy it properly, and leave their team able to run it with confidence.
        </p>
        <p>
          That is why the business is built around quick wins that recover revenue, reduce drag, speed response, or remove repetitive work.
        </p>
      </article>
    </div>
  </section>

  <section class="section" data-tone="sand">
    <div class="container split-grid">
      <article class="about-panel rich-text" data-reveal>
        <span class="eyebrow">Stack logic</span>
        <h2>Why OpenClaw plus Claude.</h2>
        <p>
          OpenClaw handles the action layer. Claude supports the reasoning, drafting, and decision-support layer. Together they make practical automations possible inside the workflow rather than in a slide deck.
        </p>
        <p>
          The stack matters because it has to work. It is not the hero story.
        </p>
      </article>
      <article class="about-panel rich-text" data-reveal>
        <span class="eyebrow">Credibility note</span>
        <h2>Built with operating seriousness.</h2>
        <p>
          {siteConfig.credibilityNote} can sit behind the brand where useful, but the site is designed so Clawsome remains the hero-level signal.
        </p>
        <p>
          If you want the founder note to be more explicit at launch, the copy and contact details live in easy-to-edit config files.
        </p>
      </article>
    </div>
  </section>

  <CTASection />
</BaseLayout>
