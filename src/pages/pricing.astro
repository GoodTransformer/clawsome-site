---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import { faqs } from "@data/faqs";
import { managedOperationsNote, offers } from "@data/offers";
import { serviceSchema } from "@data/schema";
import { getPrimaryCtaHref } from "@data/site";

const primaryHref = getPrimaryCtaHref();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<BaseLayout
  title="Pricing | Clawsome"
  description="Clear price bands for the audit, quick-win sprint, care plan, and expansion work."
  pathname="/pricing/"
  schema={[
    serviceSchema(
      "Pricing for Clawsome quick-win agent services",
      "Clear, premium pricing for Clawsome audits, quick-win builds, care plans, and expansion work.",
      "/pricing/"
    ),
    faqSchema
  ]}
>
  <section class="page-hero">
    <div class="container page-hero__shell">
      <div>
        <p class="eyebrow">Pricing</p>
        <h1>Clear price bands. Clean scope.</h1>
        <p class="page-intro">
          The first step should feel easy to buy and serious enough to trust.
        </p>
      </div>
      <div class="page-note">
        <p>Audit first. Quick win next. Care or expansion after proof.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container offer-table">
      {offers.map((offer) => (
        <article class="offer-row">
          <div class="offer-main">
            <p class="offer-kicker">{offer.emphasis}</p>
            <h2>{offer.name}</h2>
            <p>{offer.summary}</p>
            <ul class="editorial-list">
              {offer.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
          <div class="offer-side">
            <div class="offer-price">{offer.price}</div>
            <ButtonLink href="/contact/" variant="ghost">
              {offer.ctaLabel}
            </ButtonLink>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tint">
    <div class="container compact-brand-block">
      <div>
        <p class="eyebrow">Later stage</p>
        <h2>{managedOperationsNote.title}</h2>
      </div>
      <div>
        <p>{managedOperationsNote.text}</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container editorial-shell">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Short answers to the obvious questions.</h2>
      </div>
      <FAQAccordion items={faqs} />
    </div>
  </section>

  <section class="section section-cta">
    <div class="container cta-shell">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Bring the workflow, not a theory deck.</h2>
        <p>We will tell you if it is a good first agent.</p>
      </div>
      <div class="button-row">
        <ButtonLink href={primaryHref} variant="primary" external={primaryHref.startsWith("http")}>
          Book an audit
        </ButtonLink>
        <ButtonLink href="/contact/" variant="secondary">
          Contact Clawsome
        </ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
