---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import Logo from "@components/Logo.astro";
import { faqs } from "@data/faqs";
import { managedOperationsNote, offers } from "@data/offers";
import { serviceSchema } from "@data/schema";
import { getPrimaryCtaHref } from "@data/site";

const primaryHref = getPrimaryCtaHref();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<BaseLayout
  title="Pricing | Clawsome"
  description="Clear price bands for the audit, quick-win sprint, care plan, and expansion work."
  pathname="/pricing/"
  schema={[
    serviceSchema(
      "Pricing for Clawsome quick-win agent services",
      "Clear, premium pricing for Clawsome audits, quick-win builds, care plans, and expansion work.",
      "/pricing/"
    ),
    faqSchema
  ]}
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <div class="page-hero__brand">
          <Logo tone="dark" />
        </div>
        <h1>Clear price bands.</h1>
        <p class="page-intro">Enough scope to buy with confidence. No sprawl.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="offer-stack">
        {offers.map((offer, index) => (
          <article class="offer-item">
            <p class="offer-index">0{index + 1}</p>
            <div class="offer-copy">
              <h2>{offer.name}</h2>
              <p>{offer.summary}</p>
            </div>
            <ul class="editorial-list editorial-list--compact">
              {offer.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
            <div class="offer-side">
              <div class="offer-price">{offer.price}</div>
              <ButtonLink href="/contact/" variant="ghost">
                {offer.ctaLabel}
              </ButtonLink>
            </div>
          </article>
        ))}
      </div>

      <div class="pricing-note">
        <p>{managedOperationsNote.title}: {managedOperationsNote.text}</p>
        <p>Pilot walkthroughs are shown in audit conversations. Public case studies follow live deployments.</p>
      </div>
    </div>
  </section>

  <section class="section section-light faq-section">
    <div class="container">
      <div class="section-head">
        <h2>Questions.</h2>
      </div>
      <FAQAccordion items={faqs} />
    </div>
  </section>

  <section class="section section-cta">
    <div class="container closing-shell">
      <div>
        <h2>Bring the workflow, not a theory deck.</h2>
        <p>We will tell you if it is a good first agent.</p>
      </div>
      <div class="button-row">
        <ButtonLink href={primaryHref} variant="primary" external={primaryHref.startsWith("http")}>
          Book an audit
        </ButtonLink>
        <ButtonLink href="/contact/" variant="secondary">
          Contact Clawsome
        </ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
