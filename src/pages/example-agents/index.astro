---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import CTASection from "@components/CTASection.astro";
import PageHero from "@components/PageHero.astro";
import { serviceSchema } from "@data/schema";
import { useCases } from "@data/useCases";
---

<BaseLayout
  title="Example Agents | Clawsome"
  description="Three commercially legible example agents for SMEs: Meta Ads, Lead Response, and Admin Recovery."
  pathname="/example-agents/"
  schema={serviceSchema(
    "Example AI agents for SME workflows",
    "Three vivid example agents that show how Clawsome approaches quick-win automation for SMEs.",
    "/example-agents/"
  )}
>
  <PageHero
    eyebrow="Example agents"
    title="Three vivid entry points. No sprawling service maze."
    text="These examples do most of the explanatory work. Each one solves a pain that buyers recognise quickly, and each one can be bounded, supervised, and tied to a clear commercial outcome."
    bullets={[
      "One useful workflow first",
      "Human control where it matters",
      "Operator training built into the handover"
    ]}
  />

  <section class="section" data-tone="paper">
    <div class="container use-case-grid">
      {useCases.map((item) => (
        <article class="use-case-panel" data-reveal>
          <p class="kicker">{item.name}</p>
          <h2>{item.summary}</h2>
          <div class="split-grid" style="margin-top: 1.5rem;">
            <div class="rich-text">
              <h3>Workflow pain</h3>
              <p>{item.pain}</p>
            </div>
            <div class="rich-text">
              <h3>Agent takes over or accelerates</h3>
              <ul class="list">
                {item.whatItDoes.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            </div>
            <div class="rich-text">
              <h3>What stays with the human</h3>
              <ul class="list">
                {item.whatStaysHuman.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            </div>
            <div class="rich-text">
              <h3>Likely outcomes</h3>
              <ul class="list">
                {item.outcomes.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
              <p class="muted">{item.whoItSuits.join(" • ")}</p>
            </div>
          </div>
          <div class="button-row" style="margin-top: 1.5rem;">
            <ButtonLink href={`/use-cases/${item.slug}/`} variant="primary" track="use_case_page_view" trackLabel={item.name}>
              View {item.shortLabel}
            </ButtonLink>
            <ButtonLink href="/contact/" variant="ghost">
              Discuss this use case
            </ButtonLink>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTASection secondaryHref="/contact/" />
</BaseLayout>
