---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
---

<BaseLayout
  title="Page Not Found | Clawsome"
  description="The page could not be found."
  pathname="/404/"
  noindex={true}
>
  <section class="page-hero">
    <div class="container page-hero__content">
      <div data-reveal>
        <span class="eyebrow">404</span>
        <h1>That route has slipped the workflow.</h1>
        <p class="lede muted">
          The page you were looking for is not here. The best next move is to go back to the homepage or straight to the example agents.
        </p>
        <div class="button-row" style="margin-top: 1.75rem;">
          <ButtonLink href="/" variant="primary">Back to home</ButtonLink>
          <ButtonLink href="/example-agents/" variant="secondary">See example agents</ButtonLink>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
