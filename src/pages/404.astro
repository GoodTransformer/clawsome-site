---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
---

<BaseLayout
  title="Page Not Found | Clawsome"
  description="The page could not be found."
  pathname="/404/"
  noindex={true}
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <h1>That page is gone.</h1>
        <p class="page-intro">Go back to the homepage or straight to the use cases.</p>
      </div>
      <div class="button-row">
        <ButtonLink href="/" variant="primary">Home</ButtonLink>
        <ButtonLink href="/use-cases/" variant="secondary">Use cases</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
