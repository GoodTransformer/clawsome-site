---
import BaseLayout from "@layouts/BaseLayout.astro";
import Logo from "@components/Logo.astro";
import { privacySections } from "@data/legal";
---

<BaseLayout
  title="Privacy Policy | Clawsome"
  description="Privacy policy template for the Clawsome website and enquiry flow."
  pathname="/privacy-policy/"
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <div class="page-hero__brand">
          <Logo tone="dark" />
        </div>
        <h1>Privacy policy.</h1>
        <p class="page-intro">Short, editable, and ready for final legal review.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container legal-shell">
      {privacySections.map((section) => (
        <article class="legal-block">
          <h2>{section.heading}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
