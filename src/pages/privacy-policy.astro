---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { privacySections } from "@data/legal";
---

<BaseLayout
  title="Privacy Policy | Clawsome"
  description="Editable privacy policy template for the Clawsome website and enquiry flow."
  pathname="/privacy-policy/"
>
  <PageHero
    eyebrow="Privacy policy"
    title="A clear, editable privacy base for launch."
    text="This page is intentionally concise. It covers the website enquiry flow and should be finalised with legal review before launch."
  />

  <section class="section" data-tone="paper">
    <div class="container stack">
      {privacySections.map((section) => (
        <article class="legal-panel rich-text" data-reveal>
          <h2>{section.heading}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
