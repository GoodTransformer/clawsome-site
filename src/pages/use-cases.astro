---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import Logo from "@components/Logo.astro";
import { serviceSchema } from "@data/schema";
import { getPrimaryCtaHref } from "@data/site";
import { useCases } from "@data/useCases";

const primaryHref = getPrimaryCtaHref();
---

<BaseLayout
  title="Use Cases | Clawsome"
  description="Three clear quick-win use cases for SMEs: Meta Ads, Lead Response, and Admin Recovery."
  pathname="/use-cases/"
  schema={serviceSchema(
    "Quick-win AI agent use cases",
    "Three fast, commercially legible ways for SMEs to start with Clawsome.",
    "/use-cases/"
  )}
>
  <section class="page-hero">
    <div class="container page-hero__shell page-hero__shell--single">
      <div class="page-hero__copy">
        <div class="page-hero__brand">
          <Logo tone="dark" />
        </div>
        <h1>Three easy ways to start.</h1>
        <p class="page-intro">Pick growth, follow-up, or admin. Start where the value is easiest to see.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container use-case-page">
      {useCases.map((item, index) => (
        <article class="use-case-feature" id={item.slug}>
          <div class="use-case-feature__lead">
            <p class="case-index">0{index + 1}</p>
            <div>
              <p class="case-name">{item.name}</p>
              <h2>{item.headline}</h2>
              <p class="case-summary">{item.summary}</p>
              <p class="case-line"><strong>Problem</strong>{item.problem}</p>
              <p class="case-line"><strong>Outcome</strong>{item.outcome}</p>
            </div>
          </div>

          <div class="use-case-feature__grid">
            <div>
              <p class="mini-heading">Agent handles</p>
              <ul class="editorial-list editorial-list--compact">
                {item.handles.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            </div>
            <div>
              <p class="mini-heading">Human keeps</p>
              <ul class="editorial-list editorial-list--compact">
                {item.human.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            </div>
            <div>
              <p class="mini-heading">Commercial outcomes</p>
              <ul class="editorial-list editorial-list--compact">
                {item.results.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
              <p class="fit-line">{item.suits}</p>
            </div>
          </div>

          <div class="use-case-feature__cta">
            <ButtonLink href="/contact/" variant="primary">
              {item.ctaLabel}
            </ButtonLink>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-cta">
    <div class="container closing-shell">
      <div>
        <h2>Choose the workflow with the clearest value.</h2>
        <p>That is usually the right first build.</p>
      </div>
      <div class="button-row">
        <ButtonLink href={primaryHref} variant="primary" external={primaryHref.startsWith("http")}>
          Book an audit
        </ButtonLink>
        <ButtonLink href="/pricing/" variant="secondary">
          See pricing
        </ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
